NODE_ENV=production
PORT=4000

# Datenbank — "db" ist der interne Service-Name
DATABASE_URL=postgres://sve_trainer:SICHERES_PASSWORT@db:5432/sve_trainer

# Auth — langen zufälligen String verwenden, z.B.: openssl rand -hex 32
JWT_SECRET=HIER_LANGEN_ZUFAELLIGEN_STRING_EINSETZEN
JWT_EXPIRES_IN=7d

# CORS — muss exakt mit der Produktions-URL übereinstimmen
FRONTEND_URL=https://fussball-editor.xn--mller-tech-9db.de

# Export-Worker (noch nicht aktiv)
REDIS_URL=redis://redis:6379
EXPORT_OUTPUT_DIR=/data/exports
