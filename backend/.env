# Beispiel-Konfiguration — kopieren nach .env und Werte anpassen
NODE_ENV=development
PORT=4000

# Datenbank
DATABASE_URL=postgres://sve_trainer:changeme@localhost:5432/sve_trainer

# Auth
JWT_SECRET=bitte-langen-zufaelligen-string-hier-einsetzen
JWT_EXPIRES_IN=7d

# Frontend-URL für CORS
FRONTEND_URL=http://localhost:5173

# Export-Worker
REDIS_URL=redis://redis:6379
EXPORT_OUTPUT_DIR=/data/exports
